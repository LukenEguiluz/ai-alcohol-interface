# Copia a .env y ajusta. Docker Compose sustituye ${VAR} desde .env en la misma carpeta.

# Obligatorio en producción con dominio propio (evita Invalid HTTP_HOST / 400):
DJANGO_ALLOWED_HOSTS=aialcohol.leyluz.com,localhost,127.0.0.1

# Recomendado con HTTPS (admin Django y CSRF):
CSRF_TRUSTED_ORIGINS=https://aialcohol.leyluz.com

# Orígenes del navegador para la API (CORS); separados por coma:
# CORS_ORIGINS=https://aialcohol.leyluz.com

# DEBUG=False
# DJANGO_SECRET_KEY=...
# POSTGRES_PASSWORD=...
